{
  "name": "@setecastronomy/wc26-results",
  "version": "3.0.0",
  "description": "Real FIFA World Cup 2026 group-stage results as a versioned data package — major version = matchday (3.x = group stage complete)",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "world-cup",
    "2026",
    "results",
    "data",
    "football",
    "soccer"
  ],
  "devDependencies": {
    "@setecastronomy/wc26-standings-engine": "*",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
