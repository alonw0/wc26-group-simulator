    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@fastify/static": "^8.0.0",
    "@setecastronomy/wc26-standings-engine": "*",
    "fastify": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.19.43",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0"
  }
}
