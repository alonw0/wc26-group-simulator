{
  "name": "@wc26/api",
  "private": true,
  "version": "0.1.0",
  "description": "WC26 group simulator API — Fastify backend consuming @setecastronomy/wc26-standings-engine",
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
